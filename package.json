{
  "name": "vgc-helper",
  "version": "0.1.0",
  "description": "Pokemon VGC teambuilder, stat and damage calculator",
  "main": "./out/main/index.js",
  "author": "Kamran",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win nsis portable",
    "release": "electron-vite build && electron-builder --win nsis --publish always",
    "icons": "node scripts/gen-pwa-icons.mjs",
    "build:web": "vite build --config vite.config.web.ts",
    "dev:web": "vite --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts --host",
    "cap:sync": "npm run build:web && cap sync android",
    "cap:open": "cap open android",
    "cap:apk": "npm run build:web && cap sync android && cap open android",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "build": {
    "appId": "com.kamran.vgchelper",
    "productName": "VGC Helper",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "VGC-Helper-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "VGC-Helper.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BakedDevGit",
        "repo": "vgc-helper",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capgo/capacitor-updater": "^8.51.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@pkmn/data": "^0.10.11",
    "@pkmn/dex": "^0.10.11",
    "@pkmn/img": "^0.3.4",
    "@smogon/calc": "^0.11.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.5"
  }
}
